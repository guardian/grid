{
  "name": "kupua",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Modern frontend for Grid — the Guardian's image DAM",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:full": "./scripts/run-e2e.sh",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:smoke": "node scripts/run-smoke.mjs",
    "test:perf": "node e2e-perf/run-audit.mjs",
    "test:experiment": "npx playwright test --config playwright.experiments.config.ts",
    "test:diag": "npx playwright test --config=playwright.debug.config.ts --headed"
  },
  "dependencies": {
    "@guardian/cql": "^1.8.4",
    "@tanstack/react-router": "^1.168.3",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.6",
    "@tanstack/router-zod-adapter": "^1.81.5",
    "date-fns": "^4.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/credential-providers": "^3.1014.0",
    "@eslint/js": "^9.29.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.8",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  }
}
