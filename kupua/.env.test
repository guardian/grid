# Unit test overrides — vitest loads .env.test which takes priority over .env.
#
# The .env file sets low thresholds (500) to exercise the deep seek path
# in e2e tests against real local ES. But unit tests use MockDataSource
# which only handles the shallow (from/size) path, so we restore the
# production defaults here.

VITE_MAX_RESULT_WINDOW=100000
VITE_DEEP_SEEK_THRESHOLD=10000
